# Configurações para Deploy via SFTP (deploy_web.sh e deploy_web.ps1)
# Copie este arquivo para .env e preencha com as credenciais do seu servidor.

SFTP_HOST=seu-servidor.com
SFTP_PORT=22
SFTP_USER=usuario
SFTP_REMOTE_DIR=/caminho/no/servidor
# SFTP_KEY=/caminho/para/chave_id_rsa (Opcional - caminho para a chave SSH privada)
# SFTP_PASS=sua_senha (Opcional - requer sshpass no linux para deploy_web.sh)
